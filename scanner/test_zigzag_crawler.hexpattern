/* Pseudocode
    x = i % (2 * bounds.x + 2)
    if(x > bounds.x) x = (2 * bounds.x) - x + 1
    y = floor(i / (bounds.x + 1)) % (2 * bounds.y + 2)
    if(y > bounds.y) x = (2 * bounds.y) - y + 1
    z = floor(i / (bounds.x + 1) / (bounds.y + 1)) % bounds.z
    if(z > bounds.z) break
 */
